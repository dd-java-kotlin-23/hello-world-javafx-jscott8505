<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Text?>
<BorderPane xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="edu.cnm.deepdive.helloworld.controller.MainController"
  stylesheets="@../styles/styles.css">

  <top>
    <Text>This is an example of a text widget.</Text>
  </top>

  <center>
    <Text fx:id="currentCount"/>
  </center>

  <bottom>
    <HBox>

      <Button
        onAction="#update"
        text="Update"/>
      <Region
        HBox.hgrow="ALWAYS"/>

      <Button
        onAction="#reset"
        text="Reset"/>

    </HBox>
  </bottom>

</BorderPane>
