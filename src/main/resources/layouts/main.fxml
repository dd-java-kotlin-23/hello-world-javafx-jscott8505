<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Text?>
<BorderPane xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="edu.cnm.deepdive.helloworld.controller.MainController"
  prefHeight="400.0" prefWidth="600.0">

  <top>
    <Text>This is an example of a text widget.</Text>
  </top>

  <center>
    <Text fx:id="currentCount"/>
  </center>

  <bottom>
    <Button onAction="#update">Update</Button>
  </bottom>

</BorderPane>
